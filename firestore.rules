rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Services: Public read, admin write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Barbers: Public read, admin write
    match /barbers/{barberId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Availability: Public read, admin write
    match /availability/{availId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Blocked Slots: Public read (for booking checks), admin write
    match /blockedSlots/{slotId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Bookings: Public create (for booking), admin read/write
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true; // Customers can create bookings
      allow update, delete: if request.auth != null; // Only admin can modify
    }
  }
}
